        MENUITEM "全選(&A)",        IDM_RESULT_SETSEL
        MENUITEM "取消選擇",        IDM_RESULT_UNSETSEL
        MENUITEM SEPARATOR
        MENUITEM "自動換行",        IDM_RESULT_WRAPLINE
        MENUITEM "清除結果(&R)",    IDM_RESULT_CLEARALL
        MENUITEM "關閉此視窗(&W)",  IDM_RESULT_CLOSE
    END
END

