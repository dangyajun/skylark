IDR_LBREAK_MENU  MENUEX DISCARDABLE
BEGIN
    POPUP "0"
    {
        MENUITEM "DOS換行符號 (\\r\\n)", IDM_LBREAK_1
        MENUITEM "MAC換行符號 (\\r)",    IDM_LBREAK_2
        MENUITEM "Unix換行符號 (\\n)",   IDM_LBREAK_3
    }
END

IDR_CODEING_MENU MENUEX DISCARDABLE
BEGIN
    POPUP "0", -1, MFT_STRING, MFS_ENABLED, 0
    {
        POPUP "Unicode"
        BEGIN
            MENUITEM "UTF-8",                        IDM_UNI_UTF8
            MENUITEM "UTF-8(BOM)",                   IDM_UNI_UTF8B
            MENUITEM "UTF-16LE",                     IDM_UNI_UTF16LEB
            MENUITEM "UTF-16BE",                     IDM_UNI_UTF16BEB
            MENUITEM "UTF-32LE",                     IDM_UNI_UTF32LE
            MENUITEM "UTF-32BE",                     IDM_UNI_UTF32BE
        END
        POPUP "ANSI"
        BEGIN
            MENUITEM "windows-1250 (中歐)",          IDM_ANSI_1
            MENUITEM "windows-1251 (西裡爾文)",      IDM_ANSI_2
            MENUITEM "windows-1252 (拉丁語)",        IDM_ANSI_3
            MENUITEM "windows-1253 (希臘語)",        IDM_ANSI_4
            MENUITEM "windows-1254 (土耳其語)",      IDM_ANSI_5
            MENUITEM "windows-1255 (希伯來語)",      IDM_ANSI_6
            MENUITEM "windows-1256 (阿拉伯語)",      IDM_ANSI_7
            MENUITEM "windows-1257 (波羅的海)",      IDM_ANSI_8
            MENUITEM "windows-1258 (越南)",          IDM_ANSI_9
            MENUITEM "cp874 (泰語)",                 IDM_ANSI_10
            MENUITEM "cp932 (日語 Shift_JIS)",       IDM_ANSI_11
            MENUITEM "cp936 (簡體中文)",             IDM_ANSI_12
            MENUITEM "cp949 (韓語)",                 IDM_ANSI_13
            MENUITEM "cp950 (繁體中文 Big5)",        IDM_ANSI_14
        END
        POPUP "ISO"
        BEGIN
            MENUITEM "28591 (ISO-8859-1 拉丁語)",     IDM_ISO_1
            MENUITEM "28592 (ISO-8859-2 中歐)",       IDM_ISO_2
            MENUITEM "28593 (ISO-8859-3 拉丁語3)",    IDM_ISO_3
            MENUITEM "28594 (ISO-8859-4 波羅的語)",   IDM_ISO_4
            MENUITEM "28595 (ISO-8859-5 西裡爾文)",   IDM_ISO_5
            MENUITEM "28596 (ISO-8859-6 阿拉伯語)",   IDM_ISO_6
            MENUITEM "28597 (ISO-8859-7 希臘語)",     IDM_ISO_7
            MENUITEM "28598 (ISO-8859-8 希伯來語)",   IDM_ISO_8
            MENUITEM "28599 (ISO-8859-9 拉丁語5)",    IDM_ISO_9
            MENUITEM "28600 (ISO-8859-10 北日耳曼語)",IDM_ISO_10
            MENUITEM "28601 (ISO-8859-11 拉丁/泰語)", IDM_ISO_11
            MENUITEM "28603 (ISO-8859-13 拉丁語7)",   IDM_ISO_13
            MENUITEM "28605 (ISO-8859-15 拉丁語9)",   IDM_ISO_15
            MENUITEM "28606 (ISO-8859-16 東南歐語)",  IDM_ISO_16
            MENUITEM "50225 (ISO-2022 韓語)",         IDM_ISO_KR
            MENUITEM "50227 (ISO-2022 簡體中文)",     IDM_ISO_CN
            MENUITEM "ISO-2022-JP-2 (日語)",          IDM_ISO_JP_2
            MENUITEM "ISO-2022-JP-2004 (日語)",       IDM_ISO_JP_2004
            MENUITEM "ISO-2022-JP-MS (日語)",         IDM_ISO_JP_MS
        END
        POPUP "IBM"
        BEGIN
            MENUITEM "852 (DOS - 中歐)",              IDM_IBM_1
            MENUITEM "855 (OEM - 西裡爾文)",          IDM_IBM_2
            MENUITEM "866 (DOS - 西裡爾文)",          IDM_IBM_3
        END
        POPUP "EUC"
        BEGIN
            MENUITEM "EUC-JP (日語)",                 IDM_EUC_1
            MENUITEM "EUC-TW (繁體中文)",             IDM_EUC_2
        END
        POPUP "Other"
        BEGIN
            MENUITEM "hz-gb-2312",                    IDM_OTHER_HZ
            MENUITEM "koi8-r",                        IDM_OTHER_1
            MENUITEM "mac-cyrillic",                  IDM_OTHER_2
            MENUITEM "mac-centraleurope",             IDM_OTHER_3
            MENUITEM "本地編碼",                      IDM_OTHER_ANSI
            MENUITEM "Iconv 支援",                    IDM_OTHER_ICONV,,0x00000003
            MENUITEM "二進位編碼",                    IDM_OTHER_BIN,,0x00000003
            MENUITEM "外掛編碼",                      IDM_OTHER_PLUGIN,,0x00000003
            MENUITEM "不明編碼",                      IDM_UNKNOWN,,0x00000003
        END
    }
END

